---
layout: base.njk
title: "Clases cerca de ti"
description: "Encuentra una clase de Satanás cerca de ti — ubicación, horario y contacto local."
permalink: /clases-cerca-de-ti/
---

<div class="local-hub">
  <header class="section local-hub__intro">
    <div class="container">
      <h1 class="local-hub__title">Clases cerca de ti</h1>
      <p class="local-hub__lede">
        Esta clase se realizará en las siguientes ciudades. Selecciona la tuya para ver la dirección del lugar, el horario y los ponentes, y para enviar un mensaje a los organizadores locales.
      </p>
      <button type="button" class="btn btn--primary" id="open-city-modal">Selecciona tu ciudad</button>

      <noscript>
        <div class="local-hub__noscript">
          <p>Selecciona una ciudad:</p>
          <ul>
            {% for c in cities %}
              <li><a href="/local-presentations/{{ c.slug }}/">{{ c.city }}{% if c.region %}, {{ c.region }}{% endif %}</a></li>
            {% endfor %}
          </ul>
        </div>
      </noscript>
    </div>
  </header>
</div>

<dialog class="city-modal" id="city-modal" aria-labelledby="city-modal-title">
  <div class="city-modal__inner">
    <header class="city-modal__head">
      <h2 id="city-modal-title">¿De dónde te unes?</h2>
      <p class="city-modal__sub">Irás a la página de esa ciudad con todos los detalles y el formulario de contacto.</p>
    </header>
    <ul class="city-modal__list" role="list">
      {% for c in cities %}
        <li>
          <a class="city-modal__choice" href="/local-presentations/{{ c.slug }}/">
            <span class="city-modal__choice-city">{{ c.city }}</span>
            {% if c.region %}
              <span class="city-modal__choice-region">{{ c.region }}</span>
            {% endif %}
          </a>
        </li>
      {% endfor %}
    </ul>
    <form method="dialog" class="city-modal__actions">
      <button type="submit" class="btn btn--ghost city-modal__cancel">Cancelar</button>
    </form>
  </div>
</dialog>

<script>
  (function () {
    var dialog = document.getElementById("city-modal");
    var openBtn = document.getElementById("open-city-modal");
    if (!dialog || !openBtn || typeof dialog.showModal !== "function") return;

    function openModal() {
      dialog.showModal();
      var first = dialog.querySelector(".city-modal__choice");
      if (first) first.focus();
    }

    openBtn.addEventListener("click", openModal);
    openModal();

    dialog.addEventListener("click", function (ev) {
      if (ev.target === dialog) {
        dialog.close();
      }
    });
  })();
</script>
