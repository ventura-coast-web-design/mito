---
pagination:
  data: cities
  size: 1
  alias: city
permalink: "local-presentations/{{ city.slug }}/index.html"
layout: base.njk
eleventyExcludeFromCollections: true
---
<article class="city-page">
  <header class="city-page__hero" aria-labelledby="city-page-title">
    <div class="city-page__hero-inner container">
      <nav class="city-page__crumb" aria-label="Ruta de navegación">
        <a href="/#ubicaciones">Ubicaciones</a>
        <span aria-hidden="true"> / </span>
        <span class="city-page__crumb-current">{{ city.city }}{% if city.region %}, {{ city.region }}{% endif %}</span>
      </nav>
      <p class="city-page__kicker">Exponiendo un mito</p>
      <h1 id="city-page-title" class="city-page__title">{{ city.city }}</h1>
      {% if city.region %}
        <p class="city-page__region">{{ city.region }}</p>
      {% endif %}
      {% if city.language == "es" %}
        <p class="city-page__language">Clase en español — Dave</p>
      {% elif city.language == "en" %}
        <p class="city-page__language">Class in English</p>
      {% endif %}
    </div>
  </header>
  <section class="section city-page__schedule-pair" aria-labelledby="schedule-title">
    <div class="container city-page__schedule-pair-grid">
      <div class="city-page__schedule-pair__schedule">
        <img id="schedule-title" src="/assets/presentation-schedule-spanish.png" alt="Programa de presentaciones" class="city-page__schedule-pair__img" />
        {% if city.scheduleIntro %}
          <p class="city-page__schedule-intro">{{ city.scheduleIntro }}</p>
        {% endif %}
        <ol class="city-page__sessions">
          {% for session in city.sessions %}
            <li class="city-page__session">
              {% if session.date or session.time %}
                <p class="city-page__session-when">
                  {% if session.date %}
                    <span class="city-page__session-date">{{ session.date }}</span>
                  {% endif %}
                  {% if session.time %}
                    <span class="city-page__session-time">{{ session.time }}</span>
                  {% endif %}
                </p>
              {% endif %}
              <h3 class="city-page__session-title">{{ session.title }}</h3>
              <p class="city-page__session-speaker">
                <span class="city-page__session-speaker-label">Ponente</span>
                {{ session.speaker }}
              </p>
            </li>
          {% endfor %}
        </ol>
        {% if speaker %}
          <div class="city-page__speaker" aria-labelledby="speaker-title">
            <h3 id="speaker-title" class="city-page__speaker-title">Ponente</h3>
            <div class="city-page__speaker-card">
              {% if speaker.photo %}
                <img
                  class="city-page__speaker-photo"
                  src="{{ speaker.photo }}"
                  alt="{{ speaker.name }}"
                  width="240"
                  height="240"
                  loading="lazy"
                  decoding="async"
                />
              {% endif %}
              <div class="city-page__speaker-copy">
                <h4 class="city-page__speaker-name">
                  {{ speaker.name }}{% if speaker.credentials %}, {{ speaker.credentials }}{% endif %}
                </h4>
                {% for paragraph in speaker.bio %}
                  <p>{{ paragraph }}</p>
                {% endfor %}
                {% if speaker.website %}
                  <p>
                    Visítalo en
                    <a href="{{ speaker.website }}" rel="noopener noreferrer">{{ speaker.websiteLabel or speaker.website }}</a>.
                  </p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      </div>
      {% set layoutSchedulePair = true %}
      {% include "city-contact-form.njk" %}
    </div>
  </section>

  <section class="section city-page__venue" aria-labelledby="venue-title">
    <div class="container">
      <h2 id="venue-title">Lugar</h2>
      <div class="city-page__venue-grid">
        <div class="city-page__venue-copy">
          <div class="city-page__address-block">
            {% if city.venueName %}
              <p class="city-page__venue-name">{{ city.venueName }}</p>
            {% endif %}
            <address class="city-page__address">
              {% for line in city.addressLines %}
                {{ line }}{% if not loop.last %}<br />{% endif %}
              {% endfor %}
            </address>
            {% if city.mapUrl %}
              <p class="city-page__map-link">
                <a href="{{ city.mapUrl }}" rel="noopener noreferrer">Abrir en Maps</a>
              </p>
            {% endif %}
          </div>
        </div>
        {% if mapEmbedSrc %}
          <div class="city-page__map">
            <iframe
              class="city-page__map-frame"
              title="Mapa centrado en el lugar de la presentación en {{ city.city }} (aproximado)"
              src="{{ mapEmbedSrc }}"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              allowfullscreen
            ></iframe>
          </div>
        {% endif %}
      </div>
    </div>
  </section>



</article>
