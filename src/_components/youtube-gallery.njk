<section id="videos" class="section videos" aria-labelledby="videos-title">
  <div class="container">
    <header class="section__head">
      <h2 id="videos-title">Empieza a explorar el tema:</h2>
      <p>
        Mientras esperamos que comiencen las clases, te invitamos a ver un adelanto de lo que se estará estudiando.
      </p>
    </header>

    <div class="videos__grid">
      {% for v in videos %}
        <article class="video-card video-card--teaser">
          <a class="video-card__teaser-link" href="/videos/{{ v.slug }}/">
            <div class="video-card__thumb">
              <img
                src="https://img.youtube.com/vi/{{ v.youtubeId }}/hqdefault.jpg"
                alt=""
                width="480"
                height="360"
                loading="lazy"
                decoding="async"
              />
              <span class="video-card__play" aria-hidden="true">Reproducir</span>
            </div>
            <p class="video-card__title">{{ v.title }}</p>
          </a>
          {% if v.transcript != false %}
            {% set transcriptSlug = v.transcriptSlug | default(v.slug) %}
            <p class="video-card__transcript-wrap">
              <a class="video-card__transcript" href="/transcripts/{{ transcriptSlug }}/">Transcript</a>
            </p>
          {% endif %}
        </article>
      {% endfor %}
    </div>

    <p class="videos__cta">
      <a class="btn btn--primary" href="/videos/">Todos los videos</a>
    </p>
  </div>
</section>
