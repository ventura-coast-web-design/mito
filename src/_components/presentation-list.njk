<section id="ubicaciones" class="section locations" aria-labelledby="locations-title">
  <div class="container">
    <header class="section__head">
      <h2 id="locations-title">DÓNDE SE REALIZARÁN LAS CLASES</h2>
    </header>

    <div class="locations__group" aria-labelledby="spanish-classes-title">
      <h3 id="spanish-classes-title" class="locations__group-title">en Español</h3>
      <p class="locations__group-lede">
      </p>
      <ul class="locations__list" role="list">
        {% for place in cities %}
          {% if place.language == "es" %}
            <li class="location-card location-card--featured">
              <p class="location-card__badge">Clase en español</p>
              <h4 class="location-card__title">
                {{ place.city }}{% if place.region %}, {{ place.region }}{% endif %}
              </h4>
              {% if place.venueName %}
                <p class="location-card__venue">{{ place.venueName }}</p>
              {% endif %}
              <address class="location-card__address">
                {% for line in place.addressLines %}
                  {{ line }}{% if not loop.last %}<br />{% endif %}
                {% endfor %}
              </address>
              <p class="location-card__actions">
                <a href="/local-presentations/{{ place.slug }}/"><button class="btn btn--primary" type="button">Inscríbete</button></a>
                <a class="location-card__link location-card__link--primary" href="/local-presentations/{{ place.slug }}/">
                  Detalles del lugar
                </a>
                {% if place.mapUrl %}
                  <a class="location-card__link" href="{{ place.mapUrl }}" rel="noopener noreferrer">Abrir en Maps</a>
                {% endif %}
              </p>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>

    <div class="locations__group" aria-labelledby="english-classes-title">
      <h3 id="english-classes-title" class="locations__group-title">In English</h3>
      <ul class="locations__list" role="list">
        {% for place in cities %}
          {% if place.language != "es" %}
            <li class="location-card">
              <h4 class="location-card__title">
                {{ place.city }}{% if place.region %}, {{ place.region }}{% endif %}
              </h4>
              {% if place.venueName %}
                <p class="location-card__venue">{{ place.venueName }}</p>
              {% endif %}
              <address class="location-card__address">
                {% for line in place.addressLines %}
                  {{ line }}{% if not loop.last %}<br />{% endif %}
                {% endfor %}
              </address>
              <p class="location-card__actions">
                <a href="/local-presentations/{{ place.slug }}/"><button class="btn btn--primary" type="button">Inscríbete</button></a>
                <a class="location-card__link location-card__link--primary" href="/local-presentations/{{ place.slug }}/">
                  Detalles del lugar
                </a>
                {% if place.mapUrl %}
                  <a class="location-card__link" href="{{ place.mapUrl }}" rel="noopener noreferrer">Abrir en Maps</a>
                {% endif %}
              </p>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>
</section>
