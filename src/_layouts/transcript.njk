---
layout: base.njk
mainClass: site-main--bright
---

<div class="page-header page-header--bright transcript-page__banner">
  {{ title }}
</div>

<div class="container transcript-page">
  {% if videoTitle or youtubeVideoId %}
    <div class="transcript-page__toolbar">
      {% if youtubeVideoId and videoTitle %}
        <a class="btn btn--bright-primary transcript-page__watch" href="https://www.youtube.com/watch?v={{ youtubeVideoId }}">Ver &ldquo;{{ videoTitle }}&rdquo;</a>
      {% elif youtubeVideoId %}
        <a class="btn btn--bright-primary transcript-page__watch" href="https://www.youtube.com/watch?v={{ youtubeVideoId }}">Ver en YouTube</a>
      {% elif videoTitle %}
        <span class="transcript-page__video-label">{{ videoTitle }}</span>
      {% endif %}
    </div>
  {% endif %}

  <article class="transcript-prose">
    {{ content | safe }}
  </article>

  <nav class="transcript-page__footer-nav" aria-label="Navegación de transcripciones">
    {% if backUrl %}
      <a class="btn btn--bright-outline" href="{{ backUrl }}">{{ backLabel or "Volver" }}</a>
    {% else %}
      <a class="btn btn--bright-outline" href="/transcripts/">Todas las transcripciones</a>
      <a class="btn btn--bright-outline" href="/quienes-somos/">Quiénes somos</a>
    {% endif %}
  </nav>
</div>
