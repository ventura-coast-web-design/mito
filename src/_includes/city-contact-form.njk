{% if layoutSchedulePair %}
<div class="city-page__contact city-page__contact--pair" id="contact" aria-labelledby="city-contact-title">
{% else %}
<section class="section city-page__contact" id="contact" aria-labelledby="city-contact-title">
  <div class="container">
{% endif %}
    <header class="section__head">
      <img id="city-contact-title" src="/assets/register-image.png" alt="Register now" class="city-page__schedule-pair__img" />
      <p>Register for the presentation in {{ city.city }}.</p>
    </header>

    <form
      class="contact-form"
      name="{{ city.netlifyFormName }}"
      method="POST"
      action="/thanks/"
      data-netlify="true"
      netlify-honeypot="bot-field"
    >
      <p class="contact-form__hp">
        <label>
          Do not fill this out if you are human:
          <input name="bot-field" tabindex="-1" autocomplete="off" />
        </label>
      </p>

      <input type="hidden" name="city-slug" value="{{ city.slug }}" />
      <input type="hidden" name="city-label" value="{{ city.city }}{% if city.region %}, {{ city.region }}{% endif %}" />

      <div class="contact-form__field">
        <label for="contact-name-{{ city.slug }}">First Name</label>
        <input id="contact-first-name-{{ city.slug }}" name="first-name" type="text" autocomplete="first-name" required />
      </div>

      <div class="contact-form__field">
        <label for="contact-last-name-{{ city.slug }}">Last Name</label>
        <input id="contact-last-name-{{ city.slug }}" name="last-name" type="text" autocomplete="last-name" required />
      </div>

      <div class="contact-form__field">
        <label for="contact-email-{{ city.slug }}">Email</label>
        <input id="contact-email-{{ city.slug }}" name="email" type="email" autocomplete="email" required />
      </div>

      <div class="contact-form__field">
        <label for="contact-phone-{{ city.slug }}">Phone <span class="contact-form__hint">(optional)</span></label>
        <input id="contact-phone-{{ city.slug }}" name="phone" type="tel" autocomplete="tel" />
      </div>

      <div class="contact-form__field">
        <label for="contact-how-many-{{ city.slug }}">How many people will be attending? <span class="contact-form__hint">(optional)</span></label>
        <input id="contact-how-many-{{ city.slug }}" name="how-many" type="number" min="1" value="1" inputmode="numeric" autocomplete="off" required/>
      </div>

      <div class="contact-form__field">
        <label for="contact-notes-{{ city.slug }}">How did you hear of us? <span class="contact-form__hint">(optional)</span></label>
        <textarea id="contact-notes-{{ city.slug }}" name="how-heard" rows="5"></textarea>
      </div>

      <button class="btn btn--primary" type="submit">Register</button>
    </form>
{% if layoutSchedulePair %}
</div>
{% else %}
  </div>
</section>
{% endif %}
