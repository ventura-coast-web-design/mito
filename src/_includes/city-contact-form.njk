{% if layoutSchedulePair %}
<div class="city-page__contact city-page__contact--pair" id="contact" aria-labelledby="city-contact-title">
{% else %}
<section class="section city-page__contact" id="contact" aria-labelledby="city-contact-title">
  <div class="container">
{% endif %}
    <header class="section__head">
      <img id="city-contact-title" src="/assets/register-image-spanish.png" alt="Regístrate" class="city-page__schedule-pair__img" />
      <p>Regístrate para la presentación en {{ city.city }}.</p>
    </header>
    <p>Recopilamos esta información solo para enviarte notificaciones sobre la clase. No la usaremos
      ni la compartiremos para otros fines. No venderemos ni alquilaremos esta información a nadie.
    </p>

    <form
      class="contact-form"
      name="{{ city.netlifyFormName }}"
      method="POST"
      action="/thanks/registration/"
      data-netlify="true"
      netlify-honeypot="bot-field"
    >
      <p class="contact-form__hp">
        <label>
          No completes este campo si eres humano:
          <input name="bot-field" tabindex="-1" autocomplete="off" />
        </label>
      </p>

      <input type="hidden" name="form-name" value="{{ city.netlifyFormName }}" />
      <input type="hidden" name="city-slug" value="{{ city.slug }}" />
      <input type="hidden" name="city-label" value="{{ city.city }}{% if city.region %}, {{ city.region }}{% endif %}" />

      <div class="contact-form__field">
        <label for="contact-first-name-{{ city.slug }}">Nombre</label>
        <input id="contact-first-name-{{ city.slug }}" name="first-name" type="text" autocomplete="given-name" required />
      </div>

      <div class="contact-form__field">
        <label for="contact-last-name-{{ city.slug }}">Apellido</label>
        <input id="contact-last-name-{{ city.slug }}" name="last-name" type="text" autocomplete="family-name" required />
      </div>

      <div class="contact-form__field">
        <label for="contact-email-{{ city.slug }}">Correo</label>
        <input id="contact-email-{{ city.slug }}" name="email" type="email" autocomplete="email" required />
      </div>

      <div class="contact-form__field">
        <label for="contact-phone-{{ city.slug }}">Teléfono <span class="contact-form__hint">(opcional)</span></label>
        <input id="contact-phone-{{ city.slug }}" name="phone" type="tel" autocomplete="tel" />
      </div>

      <div class="contact-form__field">
        <label for="contact-how-many-{{ city.slug }}">¿Cuántas personas asistirán? <span class="contact-form__hint">(opcional)</span></label>
        <input id="contact-how-many-{{ city.slug }}" name="how-many" type="number" min="1" value="1" inputmode="numeric" autocomplete="off" required/>
      </div>

      <div class="contact-form__field">
        <label for="contact-notes-{{ city.slug }}">¿Cómo te enteraste de nosotros? <span class="contact-form__hint">(opcional)</span></label>
        <textarea id="contact-notes-{{ city.slug }}" name="how-heard" rows="{% if layoutSchedulePair %}3{% else %}5{% endif %}"></textarea>
      </div>

      <button class="btn btn--primary" type="submit">Regístrate</button>
    </form>
{% if layoutSchedulePair %}
</div>
{% else %}
  </div>
</section>
{% endif %}
